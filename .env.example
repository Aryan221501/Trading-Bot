# Copy this file to ".env" and fill in your Binance Futures TESTNET credentials.
# Get them from https://testnet.binancefuture.com after registering/activating
# a testnet account and generating an API key pair.
#
# NEVER commit your real .env file or real API keys to version control.

BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here
BINANCE_BASE_URL=https://testnet.binancefuture.com
